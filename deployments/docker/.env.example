# NyxAI Docker Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Application Configuration
# =============================================================================
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=your-secret-key-here-change-in-production

# =============================================================================
# Service Ports
# =============================================================================
NYXAI_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
FLOWER_PORT=5555

# =============================================================================
# Database Configuration (PostgreSQL with pgvector)
# =============================================================================
POSTGRES_USER=nyxai
POSTGRES_PASSWORD=nyxai_secret_password
POSTGRES_DB=nyxai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full database URL (used by SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://nyxai:nyxai_secret_password@postgres:5432/nyxai

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Full Redis URL
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Celery Configuration
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=4

# =============================================================================
# Prometheus Configuration
# =============================================================================
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_RETENTION_TIME=15d

# =============================================================================
# Loki Configuration
# =============================================================================
LOKI_URL=http://loki:3100

# =============================================================================
# Grafana Configuration
# =============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3000

# =============================================================================
# LLM API Keys
# =============================================================================
# OpenAI API Key (required for GPT models)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (required for Claude models)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Azure OpenAI (optional, alternative to OpenAI)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01

# =============================================================================
# Model Configuration
# =============================================================================
# Default LLM model to use
DEFAULT_LLM_MODEL=gpt-4
DEFAULT_LLM_PROVIDER=openai

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Anomaly Detection Configuration
# =============================================================================
# Statistical detector settings
ANOMALY_DETECTION_SENSITIVITY=0.95
ANOMALY_DETECTION_WINDOW_SIZE=100

# Time series forecasting
FORECAST_HORIZON=24
FORECAST_CONFIDENCE_LEVEL=0.95

# =============================================================================
# Alerting Configuration
# =============================================================================
# Slack webhook URL for alerts
SLACK_WEBHOOK_URL=

# Email configuration for alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# PagerDuty integration key
PAGERDUTY_INTEGRATION_KEY=

# =============================================================================
# Security Configuration
# =============================================================================
# JWT settings
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_STRUCTURED_LOGGING=true

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_AUTO_RECOVERY=true
ENABLE_ROOT_CAUSE_ANALYSIS=true
ENABLE_ANOMALY_DETECTION=true
ENABLE_METRICS_COLLECTION=true

# =============================================================================
# Development Settings (only for local development)
# =============================================================================
# Hot reload for development
UVICORN_RELOAD=false

# Debug mode for detailed error messages
DEBUG_MODE=false

# =============================================================================
# Production Settings
# =============================================================================
# Number of Uvicorn workers (production only)
UVICORN_WORKERS=4

# SSL/TLS settings (production only)
SSL_CERT_PATH=
SSL_KEY_PATH=

# =============================================================================
# Backup and Maintenance
# =============================================================================
# Database backup schedule (cron format)
DB_BACKUP_SCHEDULE=0 2 * * *
DB_BACKUP_RETENTION_DAYS=30
